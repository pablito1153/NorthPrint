// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Productos del catálogo (diseños disponibles)
model Product {
  id        String   @id @default(cuid())
  name      String
  description String
  price     Float
  category  String   // "Clasico", "Urbano", "Minimalista", etc
  colors    String[] // Colores disponibles: ["Blanco", "Negro", "Gris"]
  images    String[] // URLs de Cloudinary
  inStock   Boolean  @default(true)
  createdAt DateTime @default(now())
}

// Diseños cargados por usuarios
model UserDesign {
  id          String   @id @default(cuid())
  userId      String   // email o session ID
  imageUrl    String   // URL de Cloudinary
  filename    String
  description String?
  createdAt   DateTime @default(now())
}

// Órdenes (para futuro)
model Order {
  id        String   @id @default(cuid())
  email     String
  items     Json     // Array de items: {productId, quantity, color}
  status    String   // "pendiente", "confirmada", "enviada", "entregada"
  total     Float
  createdAt DateTime @default(now())
}
